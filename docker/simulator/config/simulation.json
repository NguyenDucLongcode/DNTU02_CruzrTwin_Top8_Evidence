{
  "domain": {
    "service": "cruzrtwin",
    "subservice": "/asean/buildings"
  },
  "contextBroker": {
    "protocol": "http",
    "host": "orion",
    "port": 1026,
    "ngsiVersion": "2.0"
  },
  "mqtt": {
    "protocol": "mqtt",
    "host": "mosquitto",
    "port": 1883
  },
  "entities": [
    {
      "entity_name": "Device:TEMP_A101",
      "entity_type": "TemperatureSensor",
      "schedule": "*/5 * * * * *",
      "active": [
        {
          "name": "temperature",
          "type": "Number",
          "value": "attribute-function-interpolator(module.exports = { result: Math.random() * (28 - 24) + 24 };)"
        },
        {
          "name": "TimeInstant",
          "type": "DateTime",
          "value": "date-increment-interpolator({\"origin\": \"now\", \"increment\": 0})"
        }
      ]
    },
    {
      "entity_name": "Device:HUMID_A101",
      "entity_type": "HumiditySensor",
      "schedule": "*/5 * * * * *",
      "active": [
        {
          "name": "humidity",
          "type": "Number",
          "value": "attribute-function-interpolator(module.exports = { result: Math.random() * (70 - 40) + 40 };)"
        },
        {
          "name": "TimeInstant",
          "type": "DateTime",
          "value": "date-increment-interpolator({\"origin\": \"now\", \"increment\": 0})"
        }
      ]
    },
    {
      "entity_name": "Device:AIR_A101",
      "entity_type": "AirQualitySensor",
      "schedule": "*/5 * * * * *",
      "active": [
        {
          "name": "co2",
          "type": "Number",
          "value": "attribute-function-interpolator(module.exports = { result: Math.random() * (450 - 400) + 400 };)"
        },
        {
          "name": "TimeInstant",
          "type": "DateTime",
          "value": "date-increment-interpolator({\"origin\": \"now\", \"increment\": 0})"
        }
      ]
    },
    {
      "entity_name": "Device:PLUG_A101",
      "entity_type": "SmartPlug",
      "schedule": "*/5 * * * * *",
      "active": [
        {
          "name": "energy_consumption",
          "type": "Number",
          "value": "attribute-function-interpolator(module.exports = { result: Math.random() * (400 - 300) + 300 };)"
        },
        {
          "name": "TimeInstant",
          "type": "DateTime",
          "value": "date-increment-interpolator({\"origin\": \"now\", \"increment\": 0})"
        }
      ]
    },
    {
      "entity_name": "Device:SMOKE_A101",
      "entity_type": "SmokeDetector",
      "schedule": "*/5 * * * * *",
      "active": [
        {
          "name": "smoke_status",
          "type": "Number",
          "value": "attribute-function-interpolator(module.exports = { result: Math.random() > 0.95 ? 1 : 0 };)"
        },
        {
          "name": "TimeInstant",
          "type": "DateTime",
          "value": "date-increment-interpolator({\"origin\": \"now\", \"increment\": 0})"
        }
      ]
    }
  ]
}
